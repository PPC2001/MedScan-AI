# =============================================================================
# MedScan AI — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://medscan:medscan_secret@localhost:5432/medscan
SYNC_DATABASE_URL=postgresql://medscan:medscan_secret@localhost:5432/medscan

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# LLM Provider Selection
# ---------------------------------------------------------------------------
# Which provider to use for reasoning/synthesis: grok | openai | anthropic
# Falls back in order: grok → openai → anthropic → local (HF only)
LLM_PROVIDER=grok

# ---------------------------------------------------------------------------
# Grok (xAI) — Primary LLM (set this key to use Grok)
# ---------------------------------------------------------------------------
XAI_API_KEY=xai-...
GROK_MODEL=grok-3
# Grok also exposes an OpenAI-compatible endpoint:
GROK_BASE_URL=https://api.x.ai/v1

# ---------------------------------------------------------------------------
# OpenAI 
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Anthropic Claude 
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---------------------------------------------------------------------------
# LangSmith Observability
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=medscan-ai

# ---------------------------------------------------------------------------
# Pinecone (optional — used if VECTOR_STORE_BACKEND=pinecone)
# ---------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=medscan-medical
PINECONE_ENVIRONMENT=us-east-1

# ---------------------------------------------------------------------------
# Vector Store Selection
# ---------------------------------------------------------------------------
# Options: pgvector | pinecone
VECTOR_STORE_BACKEND=pgvector

# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------
HF_TOKEN=hf_...
# Device for HF inference: cpu | cuda | mps
HF_DEVICE=cpu

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# Simple API key for dev — replace with proper auth in production
API_KEY=medscan-dev-key-change-me
